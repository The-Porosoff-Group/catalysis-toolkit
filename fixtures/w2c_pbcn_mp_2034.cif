  2  '-x, -y, -z'
  3  '-x+1/2, -y+1/2, z+1/2'
  4  'x+1/2, y+1/2, -z+1/2'
  5  'x+1/2, -y+1/2, -z'
  6  '-x+1/2, y+1/2, z'
  7  '-x, y, -z+1/2'
  8  'x, -y, z+1/2'
